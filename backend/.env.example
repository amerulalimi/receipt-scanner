POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=resit

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/resit
REDIS_URL=redis://localhost:6379/0

ENVIRONMENT=development
DEBUG=true
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

SESSION_SECRET=replace-with-a-long-dev-secret-at-least-32-chars
SESSION_COOKIE_NAME=resit_sess
SESSION_TTL_SECONDS=28800
ADMIN_SESSION_COOKIE_NAME=admin_resit_sess
ADMIN_SESSION_TTL_SECONDS=28800

STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage/receipts
RUN_IN_PROCESS_WORKER=false

OPENROUTER_API_KEY=
OPENROUTER_VISION_MODEL=google/gemini-2.5-flash

MASTER_ENCRYPTION_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@resit.my
