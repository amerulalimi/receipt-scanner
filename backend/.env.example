# PostgreSQL (async SQLAlchemy + asyncpg)
DATABASE_URL=postgresql+asyncpg://resit:resit_dev@localhost:5432/resitmy
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Redis (sessions, rate limiting, job queue)
REDIS_URL=redis://localhost:6379/0

# Session
SESSION_SECRET=changeme-min-32-chars-minimum-length
SESSION_TTL_SECONDS=28800
SESSION_COOKIE_NAME=resit_sess
ADMIN_SESSION_COOKIE_NAME=admin_resit_sess
ADMIN_SESSION_TTL_SECONDS=28800

# Rate limiting (0 = disabled for local/test)
AUTH_RATE_LIMIT_MAX=0
AUTH_RATE_LIMIT_WINDOW_SECONDS=900

# Storage
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage/receipts
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# AI
OPENROUTER_API_KEY=
OPENROUTER_VISION_MODEL=google/gemini-2.5-flash

# App
ENVIRONMENT=development
DEBUG=true
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
MASTER_ENCRYPTION_KEY=

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@resit.my
