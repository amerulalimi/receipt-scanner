FROM node:20-alpine AS deps
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci

FROM node:20-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .
ARG FASTAPI_URL=http://backend:8000
ARG NEXT_PUBLIC_APP_URL=http://localhost:3000
ARG NEXT_PUBLIC_API_URL=http://localhost:8000
ARG SESSION_COOKIE_NAME=resit_sess
ARG SESSION_TTL_SECONDS=28800
ARG ADMIN_SESSION_COOKIE_NAME=admin_resit_sess
ARG ADMIN_SESSION_TTL_SECONDS=28800
ENV FASTAPI_URL=$FASTAPI_URL
ENV NEXT_PUBLIC_APP_URL=$NEXT_PUBLIC_APP_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV SESSION_COOKIE_NAME=$SESSION_COOKIE_NAME
ENV SESSION_TTL_SECONDS=$SESSION_TTL_SECONDS
ENV ADMIN_SESSION_COOKIE_NAME=$ADMIN_SESSION_COOKIE_NAME
ENV ADMIN_SESSION_TTL_SECONDS=$ADMIN_SESSION_TTL_SECONDS
ENV NEXT_TELEMETRY_DISABLED=1
RUN npm run build

FROM node:20-alpine AS runner
WORKDIR /app
ARG FASTAPI_URL=http://backend:8000
ARG NEXT_PUBLIC_APP_URL=http://localhost:3000
ARG NEXT_PUBLIC_API_URL=http://localhost:8000
ARG SESSION_COOKIE_NAME=resit_sess
ARG SESSION_TTL_SECONDS=28800
ARG ADMIN_SESSION_COOKIE_NAME=admin_resit_sess
ARG ADMIN_SESSION_TTL_SECONDS=28800
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV FASTAPI_URL=$FASTAPI_URL
ENV NEXT_PUBLIC_APP_URL=$NEXT_PUBLIC_APP_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV SESSION_COOKIE_NAME=$SESSION_COOKIE_NAME
ENV SESSION_TTL_SECONDS=$SESSION_TTL_SECONDS
ENV ADMIN_SESSION_COOKIE_NAME=$ADMIN_SESSION_COOKIE_NAME
ENV ADMIN_SESSION_TTL_SECONDS=$ADMIN_SESSION_TTL_SECONDS

COPY --from=builder /app/public ./public
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static

EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

CMD ["node", "server.js"]
